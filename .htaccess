# ============================================================
# USITTEL — Configuración Apache
# ============================================================

# ── Redirección Autogestión → Phantom ─────────────────────
Redirect 302 /autogestion https://phantom.usittel.com.ar/PHANTOM/Includes/CRM/CRM_APP/login.php
# Servir HTML y assets de texto como UTF-8 para respetar los acentos del sitio.
AddDefaultCharset UTF-8
AddType "text/html; charset=UTF-8" .html .htm
AddType "text/css; charset=UTF-8" .css
AddType "application/javascript; charset=UTF-8" .js

# ── 1. Desactivar listado de directorios ──────────────────
Options -Indexes

# ── 2. Página de error personalizada ─────────────────────
ErrorDocument 404 /pages/index.html

# ── 3. Seguridad de cabeceras HTTP ────────────────────────
<IfModule mod_headers.c>
    # Evitar que el navegador "olfatee" el tipo de contenido
    Header set X-Content-Type-Options "nosniff"
    # Protección básica contra clickjacking
    Header set X-Frame-Options "SAMEORIGIN"
    # Activar filtro XSS en navegadores legacy
    Header set X-XSS-Protection "1; mode=block"
    # Solo enviar Referrer en mismo origen
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ── 4. Bloquear acceso directo a archivos sensibles ───────
<FilesMatch "\.(env|log|json|lock|config\.js)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# ── 5. Comprimir respuestas (si mod_deflate disponible) ───
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript text/javascript
</IfModule>

# ── 6. Cache para assets estáticos ───────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    # CSS y JS se revalidan siempre para evitar conservar precios o estilos viejos.
    ExpiresByType text/css                  "access plus 0 seconds"
    ExpiresByType application/javascript    "access plus 0 seconds"
    ExpiresByType text/javascript           "access plus 0 seconds"
    ExpiresByType image/png                 "access plus 6 months"
    ExpiresByType image/webp                "access plus 6 months"
    ExpiresByType image/jpeg                "access plus 6 months"
    ExpiresByType image/svg+xml             "access plus 6 months"
    ExpiresByType font/woff2                "access plus 1 year"
</IfModule>
# CSS y JS deben revalidarse en cada carga: los precios del home dependen de main.js.
<IfModule mod_headers.c>
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "no-cache, must-revalidate"
        Header set Pragma "no-cache"
    </FilesMatch>
</IfModule>
